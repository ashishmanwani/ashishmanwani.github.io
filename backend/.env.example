# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pt_user:changeme@postgres:5432/pricetracker
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_this_to_a_random_32char_string

# ── LLM Provider (choose one) ──────────────────────────────────────────────────
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434

# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── Proxy ──────────────────────────────────────────────────────────────────────
# Options: webshare | static_file | none
PROXY_PROVIDER=none

# Webshare API key (https://webshare.io) — only if PROXY_PROVIDER=webshare
WEBSHARE_API_KEY=

# Path to plain-text proxy list (one per line: host:port:user:pass)
# Only if PROXY_PROVIDER=static_file
PROXY_STATIC_FILE_PATH=/app/proxies.txt

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_64char_hex_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── App ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
DEBUG=false
LOG_LEVEL=INFO

# ── Scraping ──────────────────────────────────────────────────────────────────
SCRAPE_CONCURRENCY_AMAZON=2
SCRAPE_CONCURRENCY_FLIPKART=3
SCRAPE_CONCURRENCY_MYNTRA=3

# ── AI Extraction ─────────────────────────────────────────────────────────────
ENABLE_LLM_FALLBACK=true
ENABLE_VISION_FALLBACK=false
LLM_CONFIDENCE_THRESHOLD=0.75
